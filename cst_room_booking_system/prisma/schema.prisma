generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  studentNumber  String    @unique
  password       String?
  name           String
  role           String    @default("user")
  year           Int
  gender         String
  phoneNumber    String    @unique
  department     String
  hasSetPassword Boolean   @default(false)
  isActive       Boolean   @default(false)
  otpExpiresAt   DateTime?
  otpHash        String?
  bookings       Booking[]

  @@index([email])
  @@index([year])
  @@index([department])
}

model Hostel {
  id               String            @id @default(uuid())
  hostelName       String
  numberOfFloor    Int
  gender           String
  status           String            @default("active")
  year             Int
  capacity         Int
  floorAllocations FloorAllocation[]
  rooms            Room[]

  @@index([status])
  @@index([year])
}

model Room {
  id         String    @id @default(uuid())
  roomNumber String
  floor      Int
  capacity   Int       @default(3)
  status     String    @default("available")
  year       Int
  hostel_id  String
  bookings   Booking[]
  hostel     Hostel    @relation(fields: [hostel_id], references: [id], onDelete: Cascade)

  @@unique([hostel_id, roomNumber])
  @@index([hostel_id])
  @@index([floor])
  @@index([status])
}

model Booking {
  id            String   @id @default(uuid())
  studentNumber String
  roomId        String
  checkIn       DateTime
  checkOut      DateTime
  createdAt     DateTime @default(now())
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [studentNumber], references: [studentNumber], onDelete: Cascade)

  @@index([studentNumber])
  @@index([roomId])
  @@index([checkIn, checkOut])
}

model FloorAllocation {
  id          String @id @default(uuid())
  hostelId    String
  floor       Int
  studentYear Int
  hostel      Hostel @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@unique([hostelId, floor])
  @@index([studentYear])
}
